def solution(my_string):
    # 기준 문자열(대문자, 소문자 순서대로 나열)
    alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"    
    # 길이 52의 정수 배열
    answer = [0] * 52
    
    # 문자열 돌면서 기준 문자열에의 위치(인덱스) 찾아 +1
    for char in my_string:
        idx = alphabet.index(char)
        answer[idx] += 1
        
    return answer
