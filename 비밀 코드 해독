from itertools import combinations

def solution(n, q, ans):
    answer = 0    
    m = len(q)
    q_sets = [set(query) for query in q]  # 속도 위해 집합 변환
    
    for comb in combinations(range(1, n + 1), 5):
        # 집합(set) 변환
        comb_set = set(comb)  # 집합 변환    
        is_possible = True
        
        for i in range(m):
            # 현재 조합과 i번째 질문의 교집합 개수가 ans[i]와 일치할 경우
            if len(comb_set & q_sets[i]) != ans[i]:
                is_possible = False
                
                # 하나라도 만족하지 않을 경우 탈락
                break
        
        # 5. 모든 질문 조건 만족한 조합일 경우 정답 카운트 1 증가
        if is_possible:
            answer += 1
            
    return answer
