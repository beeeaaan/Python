def solution(babbling):
    answer = 0
    can_speak = ["aya", "ye", "woo", "ma"]
    
    for word in babbling:
        for speak in can_speak:
            # 발음 가능한 단어를 공백으로 대체 (글자가 이어붙는 것 방지)
            word = word.replace(speak, " ")
        
        # 공백을 제거했을 때 빈 문자열이면 발음 가능한 단어
        if word.strip() == "":
            answer += 1
            
    return answer
