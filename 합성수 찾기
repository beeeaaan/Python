int solution(int n) {
    int answer = 0;

    for (int i = 4; i <= n; i++) {
        int cnt = 0;

        // 약수 개수
        for (int j = 1; j * j <= i; j++) {
            if (i % j == 0) {
                cnt += (j * j == i) ? 1 : 2;
            }
        }

        // 합성수(약수 개수 세 개 이상)
        if (cnt >= 3) {
            answer++;
        }
    }

    return answer;
}
