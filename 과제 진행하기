def to_minutes(time_str):
    # 분 단위 정수로 변환
    h, m = map(int, time_str.split(":"))
    return h * 60 + m

def solution(plans):
    answer = []
    
    # 모든 과제 시작 시간을 분 단위로 변경 및 playtime 정렬 위해 숫자로 변환
    for i in range(len(plans)):
        plans[i][1] = to_minutes(plans[i][1])
        plans[i][2] = int(plans[i][2])
    
    # 시작 시간 빠른 순서대로 과제 정렬
    plans.sort(key=lambda x: x[1])
    
    # 멈춘 과제들 저장할 스택 -> [과제 이름, 남은 시간]
    stopped = []
    
    for i in range(len(plans) - 1):
        name, start, playtime = plans[i]
        next_name, next_start, _ = plans[i+1]
        
        # 현재 과제를 끝내고도 다음 과제 시작까지 남는 시간(또는 부족한 시간)
        time_gap = next_start - start
        
        # 케이스 A: 다음 과제 시작 전까지 현재 과제를 끝낼 수 있는 경우
        if time_gap >= playtime:
            answer.append(name)  # 현재 과제 완료
            time_gap -= playtime  # 남은 시간 갱신
            
            # 시간이 남은 경우 멈춰둔 과제를 가장 최근 것부터 꺼내서 처리
            while time_gap > 0 and stopped:
                stop_name, stop_remains = stopped.pop()
                
                if time_gap >= stop_remains:
                    answer.append(stop_name)  # 멈춘 과제 완료
                    time_gap -= stop_remains
                else:
                    # 멈춘 과제를 다 끝내지 못하고 다시 스택에 넣기
                    stopped.append([stop_name, stop_remains - time_gap])
                    time_gap = 0
                    
        # 케이스 B: 다음 과제 시작 전까지 현재 과제 다 못 끝내는 경우
        else:
            # 못 끝낸 만큼의 시간 계산해서 스택에 보관
            stopped.append([name, playtime - time_gap])
            
    # 마지막 과제는 무조건 바로 끝마치기
    answer.append(plans[-1][0])
    
    # 남아있는(멈춰둔) 과제들 역순(최근에 멈춘 순서)으로 모두 완료 처리
    while stopped:
        answer.append(stopped.pop()[0])
        
    return answer
