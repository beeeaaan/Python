from itertools import product

def solution(users, emoticons):
    discount_rates = [10, 20, 30, 40]  # 할인율 종류    
    best_plus_users = 0  # 이모티콘 플러스 가입자 수
    best_total_sales = 0  # 총 판매 금액
    
    # 모든 이모티콘에 대한 할인율 조합
    for rates in product(discount_rates, repeat=len(emoticons)):
        current_plus_users = 0
        current_total_sales = 0
        
        # 각 유저별 구매 금액 및 가입 여부 계산
        for user_rate, user_budget in users:
            user_spent = 0 
            
            # 유저의 이모티콘 구매 여부 결정
            for idx, rate in enumerate(rates):
                # 유저가 원하는 할인율 이상인 경우에만 구매
                if rate >= user_rate:
                    # 할인된 가격 계산 후 누적
                    user_spent += emoticons[idx] * (100 - rate) // 100
            
            # 유저의 구매 총액이 본인의 예산 이상일 경우 이모티콘 플러스 가입
            if user_spent >= user_budget:
                current_plus_users += 1
            # 예산 미만일 경우 플러스 가입 안하고 실제 이모티콘 구매 금액에 포함
            else:
                current_total_sales += user_spent
        
        # 최대 가입자 수 우선(같을 경우 최대 판매 금액 기준으로 결과 갱신)
        if current_plus_users > best_plus_users:
            best_plus_users = current_plus_users
            best_total_sales = current_total_sales
        elif current_plus_users == best_plus_users:
            if current_total_sales > best_total_sales:
                best_total_sales = current_total_sales
                
    return [best_plus_users, best_total_sales]
