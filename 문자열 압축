def solution(s):
    # 문자열 길이가 1인 경우 압축할 수 없으므로 무조건 길이는 1
    if len(s) == 1:
        return 1
    
    answer = len(s)
    
    # 1개 단위부터 문자열 길이의 절반(len(s)//2) 단위까지
    for step in range(1, len(s) // 2 + 1):
        compressed = ""
        prev = s[0:step]  # 기준점(처음 앞부분만큼 문자열 자르기)
        count = 1
        
        # step 크기만큼 증가시키면서 이전 문자열과 비교합니다.
        for j in range(step, len(s), step):
            # 다음 토큰(문자열 조각)
            next_chunk = s[j:j+step]
            
            # 이전 조각과 동일할 경우 count 증가
            if prev == next_chunk:
                count += 1
            # 다른 조각 나온 경우 지금까지 쌓인 결과를 압축 문자열에 붙이기
            else:
                if count >= 2:
                    compressed += str(count) + prev
                else:
                    compressed += prev
                
                # 현재 조각으로 초기화
                prev = next_chunk
                count = 1
                
        # 반복문 끝나고 남아있는 마지막 문자열 조각 처리
        if count >= 2:
            compressed += str(count) + prev
        else:
            compressed += prev
            
        # 가장 짧은 길이 갱신
        answer = min(answer, len(compressed))
        
    return answer
