def solution(s):
    answer = 0
    s_list = list(s.split(" "))

    for i in range(0, len(s_list)):
        # "Z"일 경우
        if s_list[i] == "Z":
            # 바로 전에 더했던 숫자 빼기
            answer -= int(s_list[i-1])
        # "Z" 아닐 경우
        else:
            # 구한 값 반환
            answer += int(s_list[i])
    return answer
