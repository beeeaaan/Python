def solution(my_string):
    # 공백 기준 문자열 분리
    tokens = my_string.split()
    answer = int(tokens[0])
    
    # 인덱스 1번부터 끝까지 2칸씩 건너뛰며 연산자 확인
    for i in range(1, len(tokens), 2):
        operator = tokens[i]  # 연산자 (+ 또는 -)
        next_num = int(tokens[i+1])  # 연산자 바로 다음에 오는 숫자
        
        # 4. 연산자 따라 더하거나 빼주기
        if operator == '+':
            answer += next_num
        elif operator == '-':
            answer -= next_num
            
    return answer
