def solution(ineq, eq, n, m):
    # eq가 "!"인 경우(같지 않다 / 포함하지 않는다)
    if eq == "!":
        if ineq == "<":
            return 1 if n < m else 0
        else:
            return 1 if n > m else 0
            
    # eq가 "="인 경우(크거나 같다 / 작거나 같다)
    else:
        if ineq == "<":
            return 1 if n <= m else 0
        else:
            return 1 if n >= m else 0
