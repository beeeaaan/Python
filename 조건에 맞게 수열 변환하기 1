def solution(arr):
    answer = []
    
    for i in arr :
        # 50보다 크거나 같은 짝수일 경우 2로 나누기
        if i >= 50 and i % 2 == 0 :
            answer.append(i // 2)
        # 50보다 작은 홀수일 경우 2 곱하기
        elif i < 50 and i % 2 == 1 : 
            answer.append(i * 2)
        else :
            answer.append(i)
            
    return answer
