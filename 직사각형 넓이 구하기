def solution(dots):
    # x 좌표들과 y 좌표들을 각각 분리하여 리스트로 만듭니다.
    x_coords = [dot[0] for dot in dots]  # x좌표
    y_coords = [dot[1] for dot in dots]  # y좌표
    
    # 가로 길이 = x 최댓값 - 최솟값
    width = max(x_coords) - min(x_coords)
    
    # 세로 길이 = y 최댓값 - 최솟값으로 세로 길이
    height = max(y_coords) - min(y_coords)
    
    # 직사각형 넓이 = 가로 x 세로
    return width * height
